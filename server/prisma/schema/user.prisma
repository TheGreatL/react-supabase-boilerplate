model User {
    id        String    @id @default(uuid())
    email     String    @unique
    password  String
    firstName String
    lastName  String
    avatar    String?   @default("test")
    role      Role      @default(USER)
    profile   Profile?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt()
    deletedAt DateTime?
}
